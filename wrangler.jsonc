{
  // Internet Transformer — Cloudflare Worker config.
  // Person A owns this file. Coordinate binding names with the team:
  //   AI      → Workers AI (Person C)
  //   BROWSER → Browser Rendering (Person B)
  //   PAGES   → KV namespace for saved /view/{id} pages (Person A + D)
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "internet-transformer",
  "main": "src/agent/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],

  // Workers AI (generation — Person C)
  "ai": {
    "binding": "AI"
  },

  // Browser Rendering (SPA extraction fallback — Person B)
  "browser": {
    "binding": "BROWSER"
  },

  // Durable Object for the Agent (Person A)
  "durable_objects": {
    "bindings": [{ "name": "TransformerAgent", "class_name": "TransformerAgent" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["TransformerAgent"] }],

  // KV for shareable saved pages (Person A writes, Person D reads via /view/{id})
  // Create with: npx wrangler kv namespace create PAGES
  // then paste the id below.
  "kv_namespaces": [{ "binding": "PAGES", "id": "0c5ee79391b0456c918c9047c59124eb" }],

  // React frontend assets (Person D) — built by Vite into ./public
  "assets": {
    "directory": "./public"
  },

  // Generation model for the DEPLOYED worker. Kimi k2.7-code (the code default in
  // src/generate) is a reasoning model with 60-110s+ time-to-first-token on Workers
  // AI even at reasoning_effort=low — too slow for a live demo. qwen2.5-coder is a
  // fast coder model (~15-20s end to end, digits fixed). Override per-env as needed.
  "vars": {
    "GENERATION_MODEL": "@cf/qwen/qwen2.5-coder-32b-instruct"
  },

  "observability": {
    "enabled": true
  }
}
